datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ── ENUMS ──

enum UserRole {
  OWNER
  BRANCH_MANAGER
  KITCHEN_STAFF
  CASHIER
}

enum OrderStatus {
  RECEIVED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum TableStatus {
  ACTIVE
  EMPTY
}

// ── CORE MODELS ──

model Tenant {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  logo       String?
  currency   String   @default("AED") // e.g., د.إ or ر.س
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relationships
  users             User[]
  branches          Branch[]
  categories        Category[]
  menuItems         MenuItem[]
  orders            Order[]
  staffInvitations StaffInvitation[]

  @@map("tenants")
}

model User {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  branchId  String?  @map("branch_id")
  name      String
  email     String   @unique
  password  String // For NextAuth credential provider
  role      UserRole
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("users")
}

model Branch {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users            User[]
  tables           Table[]
  orders           Order[]
  staffInvitations StaffInvitation[]

  @@index([tenantId])
  @@map("branches")
}

model Table {
  id       String      @id @default(cuid())
  branchId String      @map("branch_id")
  number   Int
  qrCode   String?     @map("qr_code")
  status   TableStatus @default(EMPTY)

  // Relationships
  branch Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([branchId, number]) // Ensures table numbers are unique within a single branch
  @@map("tables")
}

model Category {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // Relationships
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menuItems MenuItem[]

  @@index([tenantId])
  @@map("categories")
}

model MenuItem {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  categoryId    String   @map("category_id")
  nameAr        String   @map("name_ar")
  nameEn        String   @map("name_en")
  descriptionAr String?  @map("description_ar")
  descriptionEn String?  @map("description_en")
  price         Decimal  @db.Decimal(10, 2)
  imageUrl      String?  @map("image_url")
  isAvailable   Boolean  @default(true) @map("is_available")
  isFeatured    Boolean  @default(false) @map("is_featured")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relationships
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([tenantId])
  @@index([categoryId])
  @@map("menu_items")
}

model Order {
  id          String      @id @default(cuid())
  tenantId    String      @map("tenant_id")
  branchId    String      @map("branch_id")
  tableId     String      @map("table_id")
  status      OrderStatus @default(RECEIVED)
  totalAmount Decimal     @map("total_amount") @db.Decimal(10, 2)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relationships
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  table      Table       @relation(fields: [tableId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([tenantId])
  @@index([branchId])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String   @map("order_id")
  menuItemId String   @map("menu_item_id")
  quantity   Int
  unitPrice  Decimal  @map("unit_price") @db.Decimal(10, 2)
  notesAr    String?  @map("notes_ar")
  notesEn    String?  @map("notes_en")

  // Relationships
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

model StaffInvitation {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  branchId  String?  @map("branch_id")
  email     String
  role      UserRole
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relationships
  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("staff_invitations")
}